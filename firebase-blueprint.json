{
  "entities": {
    "Review": {
      "title": "Review",
      "description": "User ratings and reviews.",
      "type": "object",
      "properties": {
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"]
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userName", "rating", "status", "createdAt"]
    }
  },
  "firestore": {
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of moderation-controlled reviews."
    }
  }
}
